@page "/"

@rendermode InteractiveServer

@using Simulation.DAL
@inject SimulationService SimService
@inject IJSRuntime JSRuntime

<h1>Neighborhood Energy Simulation</h1>

@if (engine == null)
{
    <p>Loading...</p>
}
else
{
    var historyRow = GetDisplayHistoryRow();

    <div class="grid">
        <div class="card">
            <h3>Time</h3>
            <p>@historyRow.CurrentTime</p>
        </div>

        <div class="card">
            <h3>Temperature</h3>
            <p>@historyRow.Temperature.ToString(format: "F1") °C</p>
            <p>Season: @historyRow.Season</p>
        </div>

        <div class="card">
            <h3>Current Load</h3>
            <p>With Battery: @historyRow.CurrentLoadWithBatteryKw.ToString(format: "F2") kW</p>
            <p>Without Battery: @historyRow.CurrentLoadKw.ToString(format: "F2") kW</p>
            <p>Peak Reduction: @((historyRow.PeakWithoutBatteryKwh - historyRow.PeakWithBatteryKwh).ToString(format: "F2")) kW</p>
        </div>

        <div class="card">
            <h3>Total Energy</h3>
            <p>@historyRow.TotalEnergyKwh.ToString(format: "F2") kWh</p>
            <p>Battery SoC: @historyRow.BatteryStateOfChargeKwh.ToString(format: "F2") kWh</p>
        </div>
    </div>

    <h3>Last 24h Load (With Battery)</h3>
    <canvas id="chart"></canvas>
}

@code {
    private SimulationEngine? engine;

    private HistoryRow GetDisplayHistoryRow()
    {
        if (engine?.CurrentHistoryRow != null)
            return engine.CurrentHistoryRow;

        // If no history is available (e.g. at the very start), create a default row based on current engine state
        return new HistoryRow(
            0,
            engine!.Clock.CurrentTime,
            engine.Neighbourhood.CurrentLoadKw,
            engine.Clock.Season,
            engine.CurrentWeather.Temperature,
            engine.Neighbourhood.CurrentLoadWithBatteryKw,
            engine.Neighbourhood.Battery?.CurrentPowerKw ?? 0,
            engine.Neighbourhood.Battery?.StateOfChargeKWh ?? 0,
            engine.Neighbourhood.TotalEnergyKWh,
            engine.Neighbourhood.PeakWithoutBattery,
            engine.Neighbourhood.PeakWithBattery);
    }

    private async Task UpdateChart()
    {
        var history = engine!.Neighbourhood.History;

        var labels = history.Select(h => h.time.ToString("HH:mm")).ToArray();
        var data = history.Select(h => h.load).ToArray();

        await JSRuntime.InvokeVoidAsync("energyChart.render",data, labels);
    }

    protected override void OnInitialized()
    {
        engine = SimService.Engine;

        SimService.OnUpdated += () =>
        {
            InvokeAsync(StateHasChanged);
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await UpdateChart();
    }
}